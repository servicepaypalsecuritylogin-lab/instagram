<section class="section newsletter">
  <div class="container" style="text-align: center; max-width: 600px;">
    <h2 class="gradient-text" style="margin-bottom: var(--spacing-md);">{{ section.settings.heading }}</h2>
    <p style="color: var(--color-text-secondary); margin-bottom: var(--spacing-xl);">
      {{ section.settings.subtext }}
    </p>
    
    <form class="newsletter-form" action="/contact#newsletter-form" method="post" style="justify-content: center;">
      <input type="hidden" name="contact[tags]" value="newsletter,{{ section.settings.customer_tag }}">
      <label for="newsletter-email-{{ section.id }}" class="sr-only">Email</label>
      <input 
        type="email" 
        id="newsletter-email-{{ section.id }}" 
        name="contact[email]" 
        class="newsletter-input" 
        placeholder="Enter your email address"
        required
        style="max-width: 350px;"
      >
      <button type="submit" class="btn btn-neon">
        {{ section.settings.button_label }}
      </button>
    </form>
    
    {% if section.settings.show_privacy_text %}
      <p style="font-size: 0.75rem; color: var(--color-text-secondary); margin-top: var(--spacing-md);">
        We respect your privacy. Unsubscribe at any time.
      </p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Revolution"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Subscribe for exclusive drops, early access, and special offers."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "customer_tag",
      "label": "Customer Tag",
      "default": "newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_privacy_text",
      "label": "Show Privacy Text",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
