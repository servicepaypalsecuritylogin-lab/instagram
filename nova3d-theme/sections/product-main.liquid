{%- assign product = all_products[section.settings.product] -%}

<section class="section product-main">
  <div class="container">
    <div class="product-page__grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-2xl);">
      <!-- Product Images -->
      <div class="product-page__media">
        <div class="product-page__main-image" style="position: relative;">
          {% if product.media.size > 1 %}
            <div class="spin-360-badge" title="Multiple images available">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
              </svg>
            </div>
          {% endif %}
          
          <img 
            id="product-image-{{ product.id }}"
            src="{{ product.featured_media | image_url: width: 800 }}"
            alt="{{ product.title }}"
            class="product-page__image lazy-image"
            style="width: 100%; height: auto; border-radius: var(--radius-lg);"
            loading="eager"
          >
        </div>
        
        {% if product.media.size > 1 %}
          <div class="thumbnail-strip">
            {% for media in product.media limit: 6 %}
              <img 
                src="{{ media | image_url: width: 150 }}"
                alt="{{ product.title }}"
                class="thumbnail {% if forloop.first %}active{% endif %}"
                data-image-id="{{ media | image_url: width: 800 }}"
                loading="lazy"
              >
            {% endfor %}
          </div>
        {% endif %}
      </div>
      
      <!-- Product Info -->
      <div class="product-page__info">
        <h1 class="product-page__title">{{ product.title }}</h1>
        
        <!-- Star Rating -->
        <div class="star-rating" style="margin: var(--spacing-md) 0;">
          <div class="star-rating__stars">
            {% for i in (1..5) %}
              <svg class="star-rating__star" viewBox="0 0 24 24">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            {% endfor %}
          </div>
          <span class="star-rating__count">(24 reviews)</span>
        </div>
        
        <!-- Price -->
        <div class="product-page__price" style="font-family: var(--font-mono); font-size: 1.5rem; margin-bottom: var(--spacing-lg);">
          {% if product.compare_at_price > product.price %}
            <span style="text-decoration: line-through; opacity: 0.5; margin-right: var(--spacing-sm);">{{ product.compare_at_price | money }}</span>
            <span style="color: var(--color-accent-neon);">{{ product.price | money }}</span>
          {% else %}
            {{ product.price | money }}
          {% endif %}
        </div>
        
        <!-- Product Form -->
        <form data-add-to-cart class="product-form">
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          
          <!-- Color Swatches -->
          {% if product.has_only_default_option == false and product.options_with_values.size > 0 %}
            {% for option in product.options_with_values %}
              {% if option.name contains 'Color' or option.name contains 'Colour' %}
                <label style="display: block; font-weight: 600; margin-bottom: var(--spacing-sm);">{{ option.name }}</label>
                <div class="color-selector">
                  {% for value in option.values %}
                    <button 
                      type="button"
                      class="color-swatch {% if option.selected_value == value %}active{% endif %}"
                      style="background-color: {{ value | handleize | replace: '-', '' }};"
                      data-product-id="{{ product.id }}"
                      data-color="{{ value }}"
                      aria-label="{{ value }}"
                    >
                      <span class="color-swatch__label">{{ value }}</span>
                    </button>
                  {% endfor %}
                </div>
              {% endif %}
            {% endfor %}
          {% endif %}
          
          <!-- Size Selector -->
          {% for option in product.options_with_values %}
            {% if option.name contains 'Size' %}
              <div style="margin-top: var(--spacing-lg);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-sm);">
                  <label style="font-weight: 600;">{{ option.name }}</label>
                  <button type="button" class="size-guide-link" data-size-guide>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10"></circle>
                      <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                      <path d="M12 17h.01"></path>
                    </svg>
                    Size Guide
                  </button>
                </div>
                <div class="size-selector">
                  {% for value in option.values %}
                    <button 
                      type="button"
                      class="size-btn {% if option.selected_value == value %}active{% endif %}"
                      data-value="{{ value }}"
                    >
                      {{ value }}
                    </button>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
          
          <!-- Quantity -->
          <div style="margin-top: var(--spacing-lg);">
            <label style="display: block; font-weight: 600; margin-bottom: var(--spacing-sm);">Quantity</label>
            <div class="quantity-selector">
              <button type="button" class="quantity-btn" data-qty-decrease>-</button>
              <input type="number" name="quantity" value="1" min="1" class="quantity-input" aria-label="Quantity">
              <button type="button" class="quantity-btn" data-qty-increase>+</button>
            </div>
          </div>
          
          <!-- Add to Cart Button -->
          <button 
            type="submit" 
            class="btn btn-neon btn-full" 
            style="margin-top: var(--spacing-xl); padding: var(--spacing-lg);"
            {% unless product.available %}disabled{% endunless %}
          >
            {% if product.available %}
              Add to Cart
            {% else %}
              Sold Out
            {% endif %}
          </button>
          
          <!-- Buy Now Button -->
          <button type="button" class="btn btn-glow btn-full" style="margin-top: var(--spacing-md);">
            Buy It Now
          </button>
        </form>
        
        <!-- Share Buttons -->
        <div class="share-buttons">
          <button class="share-button" aria-label="Share on Facebook">
            <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </button>
          <button class="share-button" aria-label="Share on Twitter">
            <svg viewBox="0 0 24 24"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
          </button>
          <button class="share-button" aria-label="Share via email">
            <svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"></rect><polyline points="22,6 12,13 2,6"></polyline></svg>
          </button>
        </div>
        
        <!-- Accordions -->
        <div class="accordion" style="margin-top: var(--spacing-2xl);">
          <div class="accordion__item">
            <button class="accordion__trigger" aria-expanded="false">
              Description
              <svg class="accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            <div class="accordion__content">
              {{ product.description }}
            </div>
          </div>
          <div class="accordion__item">
            <button class="accordion__trigger" aria-expanded="false">
              Shipping & Returns
              <svg class="accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            <div class="accordion__content">
              <p>Free shipping on orders over $100. Returns accepted within 30 days of purchase.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Sticky ATC Bar -->
  {% if section.settings.sticky_atc %}
    <div class="sticky-atc">
      <div class="sticky-atc__inner">
        <div class="sticky-atc__info">
          <img src="{{ product.featured_media | image_url: width: 100 }}" alt="{{ product.title }}" class="sticky-atc__image">
          <div>
            <div class="sticky-atc__title">{{ product.title }}</div>
            <div class="sticky-atc__price">{{ product.price | money }}</div>
          </div>
        </div>
        <div class="sticky-atc__actions">
          <form data-add-to-cart style="flex: 1; max-width: 300px;">
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            <button type="submit" class="btn btn-neon btn-full">Add to Cart</button>
          </form>
        </div>
      </div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Product Main",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "sticky_atc",
      "label": "Enable Sticky Add to Cart Bar",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product Main"
    }
  ]
}
{% endschema %}
