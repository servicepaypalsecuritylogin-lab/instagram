[
  {
    "name": "theme_info",
    "theme_name": "3D Sneaker Theme",
    "theme_version": "1.0.0",
    "theme_author": "Your Studio",
    "theme_documentation_url": "https://your-docs-url.com",
    "theme_support_url": "https://your-support-url.com",
    "logo": "logo.png"
  },
  {
    "name": "3D Settings",
    "settings": [
      {
        "type": "header",
        "content": "3D Model Configuration"
      },
      {
        "type": "text",
        "id": "glb_model_url",
        "label": "Default 3D Model URL",
        "info": "URL to your GLB/GLTF file (e.g., cdn.shopify.com/s/files/...)",
        "default": ""
      },
      {
        "type": "image_picker",
        "id": "environment_map",
        "label": "Environment Map (HDR)",
        "info": "HDR/EXR file for realistic reflections"
      },
      {
        "type": "header",
        "content": "Appearance"
      },
      {
        "type": "color",
        "id": "accent_color",
        "label": "Accent Color",
        "default": "#ff3366"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#0a0a0a"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text Color",
        "default": "#ffffff"
      },
      {
        "type": "header",
        "content": "3D Viewer Settings"
      },
      {
        "type": "checkbox",
        "id": "auto_rotate_enabled",
        "label": "Enable Auto-Rotate",
        "default": true
      },
      {
        "type": "range",
        "id": "camera_fov",
        "label": "Camera Field of View",
        "min": 30,
        "max": 75,
        "step": 1,
        "unit": "deg",
        "default": 45
      },
      {
        "type": "select",
        "id": "shadow_quality",
        "label": "Shadow Quality",
        "options": [
          {
            "value": "low",
            "label": "Low (512x512)"
          },
          {
            "value": "medium",
            "label": "Medium (1024x1024)"
          },
          {
            "value": "high",
            "label": "High (2048x2048)"
          }
        ],
        "default": "high"
      },
      {
        "type": "checkbox",
        "id": "enable_ar",
        "label": "Enable AR Quick Look",
        "default": true,
        "info": "Allow customers to view products in their space using iOS AR"
      },
      {
        "type": "header",
        "content": "Performance"
      },
      {
        "type": "checkbox",
        "id": "enable_draco",
        "label": "Enable Draco Compression",
        "default": true,
        "info": "Reduces model file size for faster loading"
      },
      {
        "type": "range",
        "id": "texture_max_size",
        "label": "Max Texture Size",
        "min": 512,
        "max": 4096,
        "step": 512,
        "unit": "px",
        "default": 2048
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Heading Font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body Font",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "label": "Heading Scale",
        "min": 1,
        "max": 2,
        "step": 0.1,
        "default": 1.2
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "colors_solid_button_labels",
        "label": "Solid Button Label",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "colors_text",
        "label": "Text Color",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "colors_background_primary",
        "label": "Primary Background",
        "default": "#0a0a0a"
      },
      {
        "type": "color",
        "id": "colors_background_secondary",
        "label": "Secondary Background",
        "default": "#1a1a1a"
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "header",
        "content": "Social Accounts"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook",
        "placeholder": "https://facebook.com/shopname"
      },
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram",
        "placeholder": "https://instagram.com/shopname"
      },
      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "Twitter",
        "placeholder": "https://twitter.com/shopname"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "YouTube",
        "placeholder": "https://youtube.com/shopname"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "TikTok",
        "placeholder": "https://tiktok.com/@shopname"
      }
    ]
  },
  {
    "name": "Checkout",
    "settings": [
      {
        "type": "header",
        "content": "Checkout Configuration"
      },
      {
        "type": "image_picker",
        "id": "checkout_banner",
        "label": "Banner Image",
        "info": "1200 x 400px recommended"
      },
      {
        "type": "image_picker",
        "id": "checkout_logo",
        "label": "Logo Image",
        "info": "240 x 240px recommended"
      },
      {
        "type": "color",
        "id": "checkout_accent_color",
        "label": "Accent Color",
        "default": "#ff3366"
      },
      {
        "type": "color",
        "id": "checkout_button_color",
        "label": "Button Color",
        "default": "#ff3366"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "header",
        "content": "Cart Drawer"
      },
      {
        "type": "checkbox",
        "id": "cart_drawer_enable",
        "label": "Enable Cart Drawer",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "cart_drawer_show_thumbnails",
        "label": "Show Product Thumbnails",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "cart_drawer_show_notes",
        "label": "Show Order Notes",
        "default": false
      }
    ]
  }
]
